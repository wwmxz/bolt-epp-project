build MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir/rounding-dynamic.c.o: C_COMPILER__rounding_Release /home/common/compiler/bolt-epp-test/llvm-test-suite/MultiSource/UnitTests/Float/rounding/rounding-dynamic.c || cmake_object_order_depends_target_rounding
  DEFINES = -DNDEBUG
  DEP_FILE = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir/rounding-dynamic.c.o.d
  FLAGS = -O3 -DNDEBUG   -w -Werror=date-time
  OBJECT_DIR = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir
  OBJECT_FILE_DIR = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir

build MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir/rounding.c.o: C_COMPILER__rounding_Release /home/common/compiler/bolt-epp-test/llvm-test-suite/MultiSource/UnitTests/Float/rounding/rounding.c || cmake_object_order_depends_target_rounding
  DEFINES = -DNDEBUG
  DEP_FILE = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir/rounding.c.o.d
  FLAGS = -O3 -DNDEBUG   -w -Werror=date-time
  OBJECT_DIR = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir
  OBJECT_FILE_DIR = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir


# =============================================================================
# Link build statements for EXECUTABLE target rounding


#############################################
# Link the executable MultiSource/UnitTests/Float/rounding/rounding

build MultiSource/UnitTests/Float/rounding/rounding: C_EXECUTABLE_LINKER__rounding_Release MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir/rounding-dynamic.c.o MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir/rounding.c.o || litsupport/build-litsupport tools/build-HashProgramOutput.sh tools/build-fpcmp tools/build-timeit tools/fpcmp-target tools/timeit-target
  FLAGS = -O3 -DNDEBUG
  OBJECT_DIR = MultiSource/UnitTests/Float/rounding/CMakeFiles/rounding.dir
  POST_BUILD = cd /home/common/compiler/bolt-epp-test/build-ts-multisource/MultiSource/UnitTests/Float/rounding && /usr/bin/cmake -E create_symlink /home/common/compiler/bolt-epp-test/llvm-test-suite/MultiSource/UnitTests/Float/rounding/rounding.reference_output /home/common/compiler/bolt-epp-test/build-ts-multisource/MultiSource/UnitTests/Float/rounding/rounding.reference_output
  PRE_LINK = :
  TARGET_FILE = MultiSource/UnitTests/Float/rounding/rounding
  TARGET_PDB = rounding.dbg


#############################################
# Utility command for edit_cache

build MultiSource/UnitTests/Float/rounding/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/common/compiler/bolt-epp-test/build-ts-multisource/MultiSource/UnitTests/Float/rounding && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build MultiSource/UnitTests/Float/rounding/edit_cache: phony MultiSource/UnitTests/Float/rounding/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build MultiSource/UnitTests/Float/rounding/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/common/compiler/bolt-epp-test/build-ts-multisource/MultiSource/UnitTests/Float/rounding && /usr/bin/cmake --regenerate-during-build -S/home/common/compiler/bolt-epp-test/llvm-test-suite -B/home/common/compiler/bolt-epp-test/build-ts-multisource
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build MultiSource/UnitTests/Float/rounding/rebuild_cache: phony MultiSource/UnitTests/Float/rounding/CMakeFiles/rebuild_cache.util

