# =============================================================================
# Object build statements for EXECUTABLE target fpcmp-target


#############################################
# Order-only phony target for fpcmp-target

build cmake_object_order_depends_target_fpcmp-target: phony || tools/CMakeFiles/fpcmp-target.dir

build tools/CMakeFiles/fpcmp-target.dir/fpcmp.c.o: C_COMPILER__fpcmp-target_Release /home/common/compiler/bolt-epp-test/llvm-test-suite/tools/fpcmp.c || cmake_object_order_depends_target_fpcmp-target
  DEFINES = -DNDEBUG
  DEP_FILE = tools/CMakeFiles/fpcmp-target.dir/fpcmp.c.o.d
  FLAGS = -O3 -DNDEBUG   -w -Werror=date-time
  OBJECT_DIR = tools/CMakeFiles/fpcmp-target.dir
  OBJECT_FILE_DIR = tools/CMakeFiles/fpcmp-target.dir


# =============================================================================
# Link build statements for EXECUTABLE target fpcmp-target


#############################################
# Link the executable tools/fpcmp-target

build tools/fpcmp-target: C_EXECUTABLE_LINKER__fpcmp-target_Release tools/CMakeFiles/fpcmp-target.dir/fpcmp.c.o
  FLAGS = -O3 -DNDEBUG
  OBJECT_DIR = tools/CMakeFiles/fpcmp-target.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_FILE = tools/fpcmp-target
  TARGET_PDB = fpcmp-target.dbg


#############################################
# Utility command for build-fpcmp

build tools/build-fpcmp: phony tools/CMakeFiles/build-fpcmp tools/fpcmp tools/fpcmp.c.o


#############################################
# Utility command for build-HashProgramOutput.sh

build tools/build-HashProgramOutput.sh: phony tools/CMakeFiles/build-HashProgramOutput.sh tools/HashProgramOutput.sh

